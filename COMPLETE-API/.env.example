# ============================================================
# .ENV.EXAMPLE — Kopyahin bilang ".env" at punan ang values
# HUWAG I-COMMIT ANG .env SA GIT!
# ============================================================

PORT=3000
DATABASE_URL=mongodb://localhost:27017/iyong-database

# I-generate gamit ang: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# I-generate gamit ang: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ENCRYPTION_KEY=

# Frontend URL (para sa CORS)
CORS_ORIGIN=http://localhost:5173

# Server-to-server API key
API_KEY=

NODE_ENV=development
