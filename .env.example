# ============================================================
# .ENV.EXAMPLE — Kopyahin ito bilang ".env" at punan ang values
# HUWAG I-COMMIT ANG .env FILE SA GIT!
# ============================================================

# 👉 PORT ng server
PORT=3000

# 👉 URL ng iyong database
DATABASE_URL=mongodb://localhost:27017/iyong-database-name

# 👉 Secret key para sa JWT access token (gawin itong mahaba at random)
JWT_SECRET=palitan-mo-ito-ng-napakahaba-at-random-na-string-123456

# 👉 HIWALAY na secret para sa refresh token (dapat iba sa JWT_SECRET)
JWT_REFRESH_SECRET=ibang-mahaba-at-random-na-string-para-sa-refresh-987654

# 👉 32-byte encryption key para sa JWT payload (dapat EXACTLY 64 hex characters)
# Para gumawa ng key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ENCRYPTION_KEY=dito-ilagay-ang-64-hex-characters-na-gawa-gamit-ang-command-sa-taas

# 👉 URL ng iyong frontend (para sa CORS)
CORS_ORIGIN=http://localhost:5173

# 👉 Secret API Key para sa server-to-server calls
API_KEY=iyong-secret-api-key-dito

# 👉 Environment (development o production)
NODE_ENV=development
